generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id          Int                     @id @default(autoincrement())
  username    String                  @unique
  password    String                  @db.Char(220)
  permissions AssginPermissionGroup[] @relation("AssginPermissionGroup")
}

model User {
  id       Int     @id @default(autoincrement())
  teamId   Int
  username String
  password String
  remark   String?

  permissions AssginPermissionGroup[] @relation("AssginPermissionGroup")
  team        Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  Post        Post[]
}

model Permission {
  id   Int    @id @default(autoincrement())
  name String

  permission_group PermissionGroupPermission[]
}

model PermissionGroup {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String? @db.Char(255)
  type        String  @db.Char(255)

  permissions           PermissionGroupPermission[]
  AssginPermissionGroup AssginPermissionGroup[]
}

model PermissionGroupPermission {
  permissionId Int
  groupId      Int

  permission Permission      @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  group      PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([permissionId, groupId])
}

model AssginPermissionGroup {
  id          Int    @id @default(autoincrement())
  groupId     Int
  relatedId   Int
  relatedType String

  group PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Admin Admin[]         @relation("AssginPermissionGroup")
  User  User[]          @relation("AssginPermissionGroup")

  @@index([groupId, relatedId])
}

model Team {
  id      Int    @id @default(autoincrement())
  name    String
  imgPath String
  contact String

  townshipId Int
  township   Township? @relation(fields: [townshipId], references: [id])
  User       User[]

  Article Article[]
}

model City {
  id   Int    @id @default(autoincrement())
  name String

  Township Township[]

  RequestHelp RequestHelp[]
}

model Township {
  id     Int    @id @default(autoincrement())
  name   String
  cityId Int
  city   City   @relation(fields: [cityId], references: [id])
  Team   Team[]

  RequestHelp RequestHelp[]
}

model RequestHelp {
  id         Int                 @id @default(autoincrement())
  cityId     Int
  townshipId Int
  location   String
  status     RequestHelpStatus   @default(pending)
  priority   RequestHelpPriority @default(low)
  image      String?
  note       String
  adminReply String              @map("admin_reply") @db.LongText
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @default(now())

  City     City     @relation(fields: [cityId], references: [id])
  Township Township @relation(fields: [townshipId], references: [id])

  @@index([townshipId, cityId, priority, status])
}

enum RequestHelpStatus {
  pending
  accepted
  rejected
}

enum RequestHelpPriority {
  high
  medium
  low
}

model Article {
  id           Int      @id @default(autoincrement())
  teamId       Int
  team         Team     @relation(fields: [teamId], references: [id])
  content      String   @db.LongText
  images       String
  type         String
  is_confirmed Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Post {
  id         Int      @id @default(autoincrement())
  userId     Int
  content    String   @db.LongText
  items      String
  images     String
  location   String
  status     String
  priority   String
  type       String
  is_deleted Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
