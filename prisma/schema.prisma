generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id          Int                     @id @default(autoincrement())
  username    String                  @unique
  password    String                  @db.Char(220)
  masters     Master[]
  permissions AssginPermissionGroup[] @relation("AssginPermissionGroup")
}

model Master {
  id         Int     @id @default(autoincrement())
  adminId    Int
  masterCode String  @db.VarChar(5)
  username   String  @unique
  password   String
  avatar     String?
  remark     String?

  admin       Admin                   @relation(fields: [adminId], references: [id])
  permissions AssginPermissionGroup[] @relation("AssginPermissionGroup")
  agents      Agent[]
  teams Team[] @relation("Team")
}

model Agent {
  id         Int     @id @default(autoincrement())
  masterId   Int
  masterCode String
  username   String
  password   String
  isLocked   Boolean
  avatar     String?
  remark     String?

  master      Master                  @relation(fields: [masterId], references: [id])
  permissions AssginPermissionGroup[] @relation("AssginPermissionGroup")
  teams Team[] @relation("Team")

  User User[]
}

model User { 
  id Int @id @default(autoincrement())
  agentId Int
  username String
  name String
  remark String? 

  agent Agent @relation(fields: [agentId],references: [id])
}

model Permission {
  id   Int    @id @default(autoincrement())
  name String

  permission_group PermissionGroupPermission[]
}

model PermissionGroup {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String? @db.Char(255)
  type        String  @db.Char(255)

  permissions           PermissionGroupPermission[]
  AssginPermissionGroup AssginPermissionGroup[]
}

model PermissionGroupPermission {
  permissionId Int
  groupId      Int

  permission Permission      @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  group      PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([permissionId, groupId])
}

model AssginPermissionGroup {
  id          Int    @id @default(autoincrement())
  groupId     Int
  relatedId   Int
  relatedType String

  group  PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Master Master[]        @relation("AssginPermissionGroup")
  Admin  Admin[]         @relation("AssginPermissionGroup")
  Agent  Agent[]         @relation("AssginPermissionGroup")

  @@index([groupId, relatedId])
}

model Team {
  id          Int    @id @default(autoincrement())
  name        String
  imgPath    String 
  relatedId   Int
  relatedType String

  Master Master[]        @relation("Team")
  Agent  Agent[]         @relation("Team")

  @@index([ relatedId])
}
