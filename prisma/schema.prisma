generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id          Int                     @id @default(autoincrement())
  username    String                  @unique
  password    String                  @db.Char(220)
  permissions AssginPermissionGroup[] @relation("AssginPermissionGroup")
}

model User {
  id       Int     @id @default(autoincrement())
  teamId   Int
  username String
  password String
  remark   String?

  permissions AssginPermissionGroup[] @relation("AssginPermissionGroup")
  team        Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Permission {
  id   Int    @id @default(autoincrement())
  name String

  permission_group PermissionGroupPermission[]
}

model PermissionGroup {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String? @db.Char(255)
  type        String  @db.Char(255)

  permissions           PermissionGroupPermission[]
  AssginPermissionGroup AssginPermissionGroup[]
}

model PermissionGroupPermission {
  permissionId Int
  groupId      Int

  permission Permission      @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  group      PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([permissionId, groupId])
}

model AssginPermissionGroup {
  id          Int    @id @default(autoincrement())
  groupId     Int
  relatedId   Int
  relatedType String

  group PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Admin Admin[]         @relation("AssginPermissionGroup")
  User  User[]          @relation("AssginPermissionGroup")

  @@index([groupId, relatedId])
}

model Team {
  id      Int    @id @default(autoincrement())
  name    String
  imgPath String

  townshipId Int
  township   Township? @relation(fields: [townshipId], references: [id])
  User       User[]
}

model City {
  id   Int    @id @default(autoincrement())
  name String

  Township Township[]
}

model Township {
  id     Int    @id @default(autoincrement())
  name   String
  cityId Int
  city   City   @relation(fields: [cityId], references: [id])
  Team   Team[]
}
